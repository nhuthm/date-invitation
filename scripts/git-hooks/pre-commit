#!/bin/sh
# Refuse to commit env files. They contain secrets and must never be in git.
# Activated via "prepare" npm script, which sets core.hooksPath to this directory.
# If you ever need to bypass (you almost certainly don't), use: git commit --no-verify

staged=$(git diff --cached --name-only --diff-filter=ACM)
bad=""

for f in $staged; do
  case "$f" in
    .env|.env.local|.env.*.local|.env.production|.env.development|.env.test)
      bad="$bad $f"
      ;;
  esac
done

if [ -n "$bad" ]; then
  printf "\ncommit blocked: env files must never be committed:\n" >&2
  for f in $bad; do
    printf "  - %s\n" "$f" >&2
  done
  printf "\nunstage with:  git restore --staged <file>\n\n" >&2
  exit 1
fi
