# Copy this file to .env.local and fill in your values.

# Create a free API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx

# Where RSVP responses get sent
TO_EMAIL=nhut@getclue.com

# Sender address.
#  - For testing, you can use: Date Invitation <onboarding@resend.dev>
#  - For production, verify your own domain on Resend and use an address from it.
FROM_EMAIL=Date Invitation <onboarding@resend.dev>
